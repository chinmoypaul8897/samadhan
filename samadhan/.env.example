# Copy to .env.local for local dev. NEVER commit real values.
# Split per backend-plan §A.5.

# ---- client (NEXT_PUBLIC_, inlined at build; not secret) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_MAPS_BROWSER_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ---- server only (Secret Manager on Cloud Run; never prefix NEXT_PUBLIC_) ----
GEMINI_API_KEY=
MAPS_SERVER_KEY=
VAPID_PRIVATE_KEY=
SCHEDULER_SA_EMAIL=

# ---- local Admin SDK credentials (NOT needed on Cloud Run — uses ADC) ----
# Either run `gcloud auth application-default login`, or point to a key file:
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# GOOGLE_CLOUD_PROJECT=your-project-id
