# Copy to .env.local for local dev. NEVER commit real values.
# Split per backend-plan §A.5.

# ---- client (NEXT_PUBLIC_, inlined at build; not secret) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_MAPS_BROWSER_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ---- server only (Secret Manager on Cloud Run; never prefix NEXT_PUBLIC_) ----
# GEMINI_API_KEY is OPTIONAL: C3 uses Vertex AI (ADC) for Gemini 2.5 Flash, not the
# Developer-API key path. Set it only if you switch genkit/index.ts back to googleAI().
GEMINI_API_KEY=
MAPS_SERVER_KEY=
VAPID_PRIVATE_KEY=
SCHEDULER_SA_EMAIL=
# SLA_SWEEP_TOKEN=   # shared secret for the SLA-breach sweep (X-Sweep-Token header). Prod injects it via Secret Manager; set it locally only to run the sweep by hand. Leave commented to keep the OIDC-only path.
# SERVICE_URL=       # this service's own origin — the OIDC audience the Cloud Scheduler sweep is verified against.

# ---- Vertex AI (Gemini) + Admin SDK — both use ADC, no key ----
# Locally: run `gcloud auth application-default login` once. Required for Vertex.
GOOGLE_CLOUD_PROJECT=samadhan-civic-7k4m2
# VERTEX_LOCATION=asia-south1   # default if unset
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json  # alternative to ADC login
