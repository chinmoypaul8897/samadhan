rules_version = '2';

// Samadhan Storage perimeter — data-shapes.md §7 (uid-scoped) + backend-plan.md C1.4.
// Citizen uploads live under reports/{uid}/... so ownership is enforced by the path.
// Admin SDK writes (issue before/after copies) bypass these rules.
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }
    function isStaff() {
      return isSignedIn() && request.auth.token.role in ['officer', 'admin'];
    }

    // Citizen capture uploads: image photo (required) + optional voice note.
    match /reports/{uid}/{allPaths=**} {
      allow read: if request.auth.uid == uid || isStaff();
      allow write: if request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('audio/.*'));
    }

    // Officer proof-of-fix (C8): a signed-in officer/admin uploads the resolution
    // photo to issues/{id}/after/{uid}.jpg. More specific than the recursive match
    // below; Storage grants on ANY matching allow, so this staff-write ORs over it.
    match /issues/{issueId}/after/{fileName} {
      allow read: if true;
      allow write: if isStaff()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Issue media (representative before / other). Public read; everything else
    // here is written by the Admin SDK, which bypasses rules.
    match /issues/{issueId}/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
